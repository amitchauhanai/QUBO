# Example environment variables for local development
# Copy to .env and replace placeholder values (do NOT commit .env to source control)

# Gemini / generative API key
GEMINI_API_KEY=REPLACE_ME

# Optional: override upstream URL (if using a custom endpoint)
# GEMINI_API_URL=https://example.com/v1/generate

# Optional: rate limit per-client per-minute
# ASSISTANT_RATE_PER_MIN=30

# Optional: model / tuning
# GEMINI_TEMP=0.2
# GEMINI_MAX_TOKENS=1024
